@page "/"

@inject IJobEngine Engine

<h3 class="mb-3">WJb Demo (WASM)</h3>

<button class="btn btn-success w-100 mb-4"
        @onclick="Start"
        data-bs-toggle="tooltip"
        title="Enqueue a demo job">
    🚀 Run Demo Job
</button>

@* ================= ACTIVE ================= *@
<h5>Active Jobs</h5>

<div class="table-responsive mb-4">
    <table class="table table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Status</th>
                <th>Progress</th>
                <th class="d-none d-md-table-cell">Message</th>
                <th class="d-none d-md-table-cell">Attempts</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in queue)
            {
                <tr class="@(t.State.Status == JobStatus.Processing ? "table-primary" : "")">
                    <td><code>@t.JobId[..6]</code></td>

                    <td>
                        <span class="badge
                            @(t.State.Status switch
                              {
                                  JobStatus.Processing => "bg-primary",
                                  JobStatus.Completed => "bg-success",
                                  JobStatus.Failed => "bg-danger",
                                  JobStatus.Cancelled => "bg-danger",
                                  _ => "bg-secondary"
                              })">
                            @t.State.Status
                        </span>
                    </td>

                    <td style="min-width:120px;">
                        <div class="progress" style="height:20px;">
                            <div class="progress-bar
                                @(t.State.Status == JobStatus.Processing
                                       ? "progress-bar-striped progress-bar-animated"
                                       : "")
                                d-flex align-items-center justify-content-center"
                                 role="progressbar"
                                 style="width:@t.State.Progress%">
                                <small>@t.State.Progress%</small>
                            </div>
                        </div>
                    </td>

                    <td class="d-none d-md-table-cell">@t.State.Message</td>
                    <td class="d-none d-md-table-cell">@t.State.Attempts</td>

                    <td>
                        <div class="d-flex justify-content-end gap-2">
                            @if (t.State.Status is JobStatus.Queued or JobStatus.Processing)
                            {
                                <button class="btn btn-sm btn-danger px-2"
                                        @onclick="() => Cancel(t.JobId)"
                                        title="Cancel">
                                    ❌
                                </button>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@* ================= RETRY ================= *@
<h5>Failed / Cancelled</h5>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Status</th>
                <th class="d-none d-md-table-cell">Message</th>
                <th>Attempts</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in retry)
            {
                <tr>
                    <td><code>@t.JobId[..6]</code></td>

                    <td>
                        <span class="badge bg-danger">
                            @t.State.Status
                        </span>
                    </td>

                    <td class="d-none d-md-table-cell">@t.State.Message</td>

                    <td>@t.State.Attempts</td>

                    <td>
                        <button class="btn btn-sm btn-warning px-2"
                                @onclick="() => Retry(t.JobId)"
                                title="Retry">
                            🔄
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<IJob> queue = new();
    private List<IJob> retry = new();

    protected override void OnInitialized()
    {
        Engine.Changed += HandleChanged;
        Load();
    }

    private void HandleChanged()
    {
        InvokeAsync(() =>
        {
            Load();
            StateHasChanged();
        });
    }

    private void Load()
    {
        queue = Engine.GetQueue().ToList();

        retry = Engine.GetHistory(new JobQuery
        {
            Statuses = new[]
            {
                JobStatus.Failed,
                JobStatus.Cancelled
            }
        }).ToList();
    }

    private void Start()
    {
        Engine.Enqueue<DemoAction, DemoPayload>(
            new DemoPayload
            {
                DelayMs = 5000,
                Text = "Done ✅"
            });
    }

    private void Retry(string id) => Engine.Retry(id);

    private void Cancel(string id) => Engine.Cancel(id);

    public void Dispose()
    {
        Engine.Changed -= HandleChanged;
    }
}
