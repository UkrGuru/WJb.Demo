@page "/"

@inject IJobClient Client
@inject IJobQuery Query
@inject IJobNotifier Notifier

<h3 class="mb-3">WJb Demo (WASM)</h3>

<button class="btn btn-success w-100 mb-4"
        @onclick="Start">
    🚀 Run Demo Job
</button>

<h5>Active Jobs</h5>

<div class="table-responsive">
    <table class="table table-sm align-middle">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Status</th>
                <th>Progress</th>
                <th class="d-none d-md-table-cell">Message</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in queue)
            {
                <tr class="@(t.Status == JobStatus.Processing ? "table-primary" : "")">

                    <td><code>@Short(t.Id)</code></td>

                    <td>
                        <span class="badge
                            @(t.Status switch
                              {
                                  JobStatus.Processing => "bg-primary",
                                  JobStatus.Completed => "bg-success",
                                  JobStatus.Failed => "bg-danger",
                                  _ => "bg-secondary"
                              })">
                            @t.Status
                        </span>
                    </td>

                    <td style="min-width:120px;">
                        <div class="progress" style="height:20px;">
                            <div class="progress-bar
                                @(t.Status == JobStatus.Processing
                                      ? "progress-bar-striped progress-bar-animated"
                                      : "")
                                d-flex align-items-center justify-content-center"
                                 role="progressbar"
                                 style="width:@t.Progress%">
                                <small>@t.Progress%</small>
                            </div>
                        </div>
                    </td>

                    <td class="d-none d-md-table-cell">@t.Message</td>

                    <td>
                        @if (t.Status is JobStatus.Pending or JobStatus.Processing)
                        {
                            <button class="btn btn-sm btn-danger"
                                    @onclick="() => Cancel(t.Id)">
                                ❌
                            </button>
                        }
                    </td>

                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private IReadOnlyList<JobInfo> queue = Array.Empty<JobInfo>();

    protected override void OnInitialized()
    {
        Notifier.Changed += HandleChanged;
        Load();
    }

    private void HandleChanged()
    {
        InvokeAsync(() =>
        {
            Load();
            StateHasChanged();
        });
    }

    private async Task Load()
        => queue = await Query.GetJobs();

    private async Task Start()
    {
        await Client.EnqueueAsync<DemoAction, DemoPayload>(
            new DemoPayload
            {
                DelayMs = 5000,
                Text = "Done ✅"
            });
    }

    private Task Cancel(string id)
        => Client.CancelAsync(id);

    private static string Short(string id)
        => id[..Math.Min(6, id.Length)];

    public void Dispose()
        => Notifier.Changed -= HandleChanged;
}