@page "/chain"
@using WJb.Demo.Wasm.Actions

@inject IJobClient Client
@inject NavigationManager Nav

<h3 class="mb-3">Chained Email Action</h3>

<div class="card">
    <div class="card-body">

        <p class="text-muted mb-3">
            Demonstrates action chaining via <code>ActionResults.Next</code>.
        </p>

        <button class="btn btn-success w-100 mb-3"
                @onclick="Start">
            <i class="bi bi-link-45deg me-1"></i>
            Run
        </button>

        <div class="small text-muted">
            Flow: Enqueue → SendEmailAction → Next(LogAction) → Complete
            <br />
            Cancel/Error → ErrorLogAction
        </div>

    </div>
</div>

<details class="mt-3">
    <summary class="text-muted">Show code</summary>

    <div class="card mt-3">
        <div class="card-body">
            <div class="row g-3">

                <div class="col-md-12">
                    <h6 class="text-muted">Start</h6>
                    <pre class="bg-light p-2 rounded small mb-0"><code>
await Client.EnqueueAsync&lt;SendEmailAction, EmailInput&gt;(
    new EmailInput { To = "test@test.com" });
                    </code></pre>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Action</h6>
                    <pre class="bg-light p-2 rounded small mb-0"><code>
public sealed class SendEmailAction(SmtpSettings? smtp)
    : JobAction&lt;EmailInput&gt;
{
    private readonly SmtpSettings? _smtp = smtp;

    public override async Task&lt;ActionResult&gt; ExecuteAsync(
        EmailInput input,
        CancellationToken ct)
    {
        var host = _smtp?.Host ?? "&lt;not configured&gt;";
        var to = input.To ?? "&lt;no recipient&gt;";

        try
        {
            ReportProgress(10, "Resolving SMTP...");
            await Task.Delay(200, ct);

            ReportProgress(40, "Connecting...");
            await Task.Delay(300, ct);

            ReportProgress(70, "Sending email...");
            await Task.Delay(400, ct);

            ct.ThrowIfCancellationRequested();

            ReportProgress(100, $"SMTP: {host}, To: {to}");

            return ActionResults.Next(
                JobCommands.Next&lt;LogAction&gt;(new LogInput
                {
                    Message = $"Email sent to {to}"
                })
            );
        }
        catch (OperationCanceledException)
        {
            return ActionResults.Next(
                JobCommands.Next&lt;ErrorLogAction&gt;(new ErrorLogInput
                {
                    Message = $"Email cancelled for {to}"
                })
            );
        }
        catch (Exception ex)
        {
            return ActionResults.Next(
                JobCommands.Next&lt;ErrorLogAction&gt;(new ErrorLogInput
                {
                    Message = $"Email failed: {ex.Message}"
                })
            );
        }
    }
}
                    </code></pre>
                </div>

                <div class="col-md-6">
                    <h6 class="text-muted">Payload</h6>
                    <pre class="bg-light p-2 rounded small mb-3"><code>
public sealed class EmailInput
{
    public string? To { get; set; }
}
                    </code></pre>

                    <h6 class="text-muted">Next Actions</h6>
                    <pre class="bg-light p-2 rounded small mb-0"><code>
public sealed class LogInput
{
    public string? Message { get; set; }
}

public sealed class ErrorLogInput
{
    public string? Message { get; set; }
}

// Success -> LogAction
// Cancel/Error -> ErrorLogAction
                    </code></pre>
                </div>

            </div>
        </div>
    </div>
</details>

@code {
    private async Task Start()
    {
        await Client.EnqueueAsync<SendEmailAction, EmailInput>(
            new EmailInput
            {
                To = "test@test.com"
            });

        Nav.NavigateTo("/");
    }
}
