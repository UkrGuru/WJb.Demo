@page "/retry"

@using WJb.Contracts
@using WJb.Demo.Wasm.Actions

@inject IJobClient Client
@inject NavigationManager Nav

<h3 class="mb-3">Retry Workflow</h3>

<div class="card">
    <div class="card-body">

        <p class="text-muted mb-3">
            Demonstrates retry policy and workflow continuation.
        </p>

        <button class="btn btn-warning w-100 mb-3"
                @onclick="Start">
            <i class="bi bi-arrow-repeat me-1"></i>
            Run
        </button>

        <div class="small text-muted">
            Flow:
            Enqueue →
            RetryEmailAction →
            Retry →
            LogAction
        </div>

        <!-- ===== CODE ===== -->
        <details class="mt-3">
            <summary class="text-muted">Show code</summary>

            <div class="card mt-3">
                <div class="card-body">

                    <div class="row g-3">

                        <div class="col-md-12">
                            <h6 class="text-muted">Start</h6>
                            <pre class="bg-light p-2 rounded small mb-0"><code>
await Client.EnqueueAsync&lt;RetryEmailAction, RetryEmailInput&gt;(
    new RetryEmailInput
    {
        To = "test@test.com"
    },
    new JobOptions
    {
        MaxRetries = 1,
        RetryDelay = TimeSpan.FromSeconds(1)
    });
                    </code></pre>
                        </div>

                        <div class="col-md-6">
                            <h6 class="text-muted">Action</h6>
                            <pre class="bg-light p-2 rounded small mb-0"><code>
public sealed class RetryEmailAction
    : JobAction&lt;RetryEmailInput&gt;
{
    private static int _attempts;

    public override async Task&lt;ActionResult&gt; ExecuteAsync(
        RetryEmailInput input,
        CancellationToken ct)
    {
        _attempts++;

        ReportProgress(
            50,
            $"Attempt {_attempts}");

        await Task.Delay(500, ct);

        if (_attempts == 1)
        {
            throw new InvalidOperationException(
                "SMTP temporarily unavailable.");
        }

        ReportProgress(
            100,
            "Email delivered.");

        _attempts = 0;

        return ActionResults.Next(
            JobCommands.Next&lt;LogAction&gt;(
                new LogInput
                {
                    Message =
                        $"Email sent to {input.To}"
                }));
    }
}
                    </code></pre>
                        </div>

                        <div class="col-md-6">
                            <h6 class="text-muted">Payload</h6>
                            <pre class="bg-light p-2 rounded small mb-3"><code>
public sealed class RetryEmailInput
{
    public string? To { get; set; }
}
                    </code></pre>

                            <h6 class="text-muted">Options</h6>
                            <pre class="bg-light p-2 rounded small mb-0"><code>
new JobOptions
{
    MaxRetries = 1,
    RetryDelay = TimeSpan.FromSeconds(1)
}

// Attempt 1 -> Fail
// Retry
// Attempt 2 -> Success
// Next(LogAction)
                    </code></pre>
                        </div>

                    </div>

                </div>
            </div>
        </details>

    </div>


</div>

@code {

    private async Task Start()
    {
        await Client.EnqueueAsync<RetryEmailAction, RetryEmailInput>(
            new RetryEmailInput
            {
                To = "test@test.com"
            },
            new JobOptions
            {
                MaxRetries = 1,
                RetryDelay = TimeSpan.FromSeconds(1)
            });

        Nav.NavigateTo("/");
    }

}