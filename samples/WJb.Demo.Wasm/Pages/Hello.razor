@page "/hello"
@using WJb.Demo.Wasm.Actions

@inject IJobClient Client
@inject NavigationManager Nav

<h3 class="mb-3">Hello Action</h3>

<div class="card">
    <div class="card-body">

        <p class="text-muted mb-3">
            Minimal job that immediately completes with a message.
        </p>

        <button class="btn btn-success w-100 mb-3"
                @onclick="Start">
            <i class="bi bi-play-fill me-1"></i>
            Run
        </button>

        <div class="small text-muted">
            Flow: Enqueue → Execute → Complete
        </div>

    </div>
</div>

<!-- ===== CODE ===== -->
<details class="mt-3">
    <summary class="text-muted">Show code</summary>

    <div class="card mt-3">
        <div class="card-body">

            <div class="row g-3">

                <!-- LEFT -->
                <div class="col-md-12">
                    <h6 class="text-muted">Start</h6>
                    <pre class="bg-light p-2 rounded small mb-0"><code>
await Client.EnqueueAsync&lt;HelloAction, HelloPayload&gt;(
    new HelloPayload { Text = "Hello from WJb ✅" });
                    </code></pre>
                </div>

                <div class="col-6">
                    <h6 class="text-muted">Action</h6>
                    <pre class="bg-light p-2 rounded small mb-0"><code>
public sealed class HelloAction : JobAction&lt;HelloPayload&gt;
{
    public override Task&lt;ActionResult&gt; ExecuteAsync(
        HelloPayload input,
        CancellationToken ct = default)
    {
        var message = input.Text ?? "Hello from WJb ✅";
        ReportProgress(100, message);
        return Task.FromResult(ActionResults.None());
    }
}
                    </code></pre>
                </div>
                <div class="col-md-6">
                    <h6 class="text-muted">Payload</h6>
                    <pre class="bg-light p-2 rounded small mb-0"><code>
public sealed class HelloPayload
{
    public string? Text { get; set; }
}
                    </code></pre>
                </div>


            </div>

        </div>
    </div>
</details>

@code {
    private async Task Start()
    {
        await Client.EnqueueAsync<HelloAction, HelloPayload>(
            new HelloPayload
            {
                Text = "Hello from WJb ✅"
            });

        Nav.NavigateTo("/");
    }
}
